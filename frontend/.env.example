# Frontend env. Copied to Vercel project settings → Environment Variables.
#
# When VITE_API_URL is empty (local dev), the Vite dev server proxies
# /api/* to http://localhost:4000 (see vite.config.ts).
#
# On Vercel, set VITE_API_URL to the deployed Render backend URL, eg
# https://sapac-chronicle-api.onrender.com

VITE_API_URL=
