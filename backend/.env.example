# --- Postgres ---
# Local dev example: postgresql://postgres:postgres@localhost:5432/sapac_chronicle
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sapac_chronicle"

# --- App ---
NODE_ENV="development"
PORT=4000
APP_ORIGIN="http://localhost:5173"

# --- Sessions ---
# 64+ random chars, eg `openssl rand -hex 48`
JWT_SECRET="change-me-to-a-long-random-string"
COOKIE_DOMAIN="localhost"

# --- Google OAuth ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"
# Restrict to Google Workspace domain ("google.com" for the NBS team)
GOOGLE_HOSTED_DOMAIN="google.com"

# --- Storage (GCS) ---
# Filled in once we wire up file uploads
GCS_BUCKET=""
GCS_KEY_FILE=""
